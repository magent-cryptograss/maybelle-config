# PickiPedia Production Container
# Thin image — MediaWiki code is bind-mounted from /var/www/pickipedia
# MariaDB socket is mounted from host

FROM php:8.2-apache

# Install PHP extensions needed by MediaWiki
RUN apt-get update && apt-get install -y \
    libicu-dev \
    libzip-dev \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    imagemagick \
    ffmpeg \
    lua5.4 \
    liblua5.4-dev \
    git \
    unzip \
    curl \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install \
        intl \
        mysqli \
        opcache \
        gd \
        zip \
        calendar \
        bcmath \
    && pecl install apcu \
    && docker-php-ext-enable apcu \
    && rm -rf /var/lib/apt/lists/*

# Apache configuration
RUN a2enmod rewrite headers
RUN sed -i '/<Directory \/var\/www\/>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

# PHP configuration matching current production settings
RUN { \
    echo 'memory_limit = 256M'; \
    echo 'upload_max_filesize = 2G'; \
    echo 'post_max_size = 2100M'; \
    echo 'max_execution_time = 600'; \
    echo 'max_input_time = 600'; \
    echo 'max_input_vars = 5000'; \
    echo 'file_uploads = On'; \
    echo ''; \
    echo '; OPcache'; \
    echo 'opcache.enable = 1'; \
    echo 'opcache.memory_consumption = 256'; \
    echo 'opcache.max_accelerated_files = 10000'; \
    echo 'opcache.validate_timestamps = 1'; \
    echo 'opcache.revalidate_freq = 60'; \
    echo ''; \
    echo '; APCu'; \
    echo 'apc.enabled = 1'; \
    echo 'apc.shm_size = 128M'; \
    echo ''; \
    echo '; Error handling'; \
    echo 'display_errors = Off'; \
    echo 'log_errors = On'; \
    echo ''; \
    echo '; Date/time'; \
    echo 'date.timezone = UTC'; \
    echo ''; \
    echo '; MySQL socket (mounted from host)'; \
    echo 'mysqli.default_socket = /var/run/mysqld/mysqld.sock'; \
    echo 'pdo_mysql.default_socket = /var/run/mysqld/mysqld.sock'; \
    } > /usr/local/etc/php/conf.d/mediawiki.ini

# No disable_functions or open_basedir — container is the sandbox
# This is what makes Scribunto (proc_open, shell_exec) work without fuss

EXPOSE 80
