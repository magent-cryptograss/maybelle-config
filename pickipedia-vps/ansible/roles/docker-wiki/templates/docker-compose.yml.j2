services:
  wiki:
    build: .
    container_name: pickipedia-wiki
    ports:
      - "127.0.0.1:8080:80"
    volumes:
      # MediaWiki code — bind-mounted so Jenkins rsync updates are instant
      - {{ mediawiki_root }}:/var/www/html
      # MariaDB socket directory — mount the directory, not the socket file,
      # so the container survives MariaDB restarts (which recreate the socket)
      - /var/run/mysqld:/var/run/mysqld
    restart: unless-stopped
