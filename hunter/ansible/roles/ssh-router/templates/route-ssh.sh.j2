USER=$1

if [ -z "$USER" ]; then
    echo "Error: No user specified"
    exit 1
fi

# Valid usernames for cross-container access
VALID_USERS=({% for user in users %}"{{ user.name }}" {% endfor %})

is_valid_user() {
    for u in "${VALID_USERS[@]}"; do
        [ "$u" = "$1" ] && return 0
    done
    return 1
}

TARGET_USER="$USER"

# Parse SSH_ORIGINAL_COMMAND
# Usage:
#   ssh sshrouter@hunter             → plain shell in your container
#   ssh sshrouter@hunter tmux        → attach to tmux session "magenta" in your container
#   ssh sshrouter@hunter justin      → join justin's container (tmux session "magenta")
#   ssh sshrouter@hunter justin jam  → join justin's container (tmux session "jam")
#   ssh sshrouter@hunter "ls -la"    → run command in your container
TARGET_SESSION="magenta"
JOIN_TMUX=false
if [ -n "$SSH_ORIGINAL_COMMAND" ]; then
    read -r FIRST_ARG REST_ARGS <<< "$SSH_ORIGINAL_COMMAND"
    if [ "$FIRST_ARG" = "tmux" ]; then
        JOIN_TMUX=true
        [ -n "$REST_ARGS" ] && TARGET_SESSION="$REST_ARGS"
    elif is_valid_user "$FIRST_ARG"; then
        JOIN_TMUX=true
        TARGET_USER="$FIRST_ARG"
        [ -n "$REST_ARGS" ] && TARGET_SESSION="$REST_ARGS"
        if [ "$TARGET_USER" != "$USER" ]; then
            echo "Joining ${TARGET_USER}'s container (session: ${TARGET_SESSION})..."
        fi
    fi
fi

CONTAINER="${TARGET_USER}-arthel"

# Check if container exists and is running
if ! docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q "^${CONTAINER}$"; then
    echo "Error: Container ${CONTAINER} not found or not running"
    exit 1
fi

if [ "$JOIN_TMUX" = true ]; then
    docker exec -it "$CONTAINER" su - magent -c "tmux new-session -A -s $TARGET_SESSION"
elif [ -n "$SSH_ORIGINAL_COMMAND" ]; then
    docker exec -it "$CONTAINER" su - magent -c "$SSH_ORIGINAL_COMMAND"
else
    docker exec -it "$CONTAINER" su - magent
fi
